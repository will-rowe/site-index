{
  "name": "site-index",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist",
    "deploy": "astro build && wrangler pages deploy ./dist --project-name worker-index",
    "deploy:cron": "wrangler deploy --config wrangler.cron.json",
    "tail:cron": "wrangler tail --config wrangler.cron.json"
  },
  "dependencies": {
    "astro": "^6.1.9",
    "node": "22.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "wrangler": "^4.84.1"
  }
}
